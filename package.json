{
  "name": "boss-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "Boss直聘求职助手 - Agent CLI",
  "bin": {
    "boss-agent": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:bun": "bun run --watch src/index.ts",
    "build": "tsup",
    "build:bun": "bun build src/index.ts --outdir dist --target bun",
    "start": "node dist/index.js",
    "start:bun": "bun dist/index.js",
    "test": "vitest run",
    "test:bun": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.38",
    "@langchain/openai": "^1.4.1",
    "asciichart": "^1.5.25",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "langchain": "^1.2.39",
    "qrcode-terminal": "^0.12.0",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
